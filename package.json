{
  "name": "twitch-song-request-player",
  "version": "2.4.0",
  "private": true,
  "main": "build/electron/main.cjs",
  "type": "module",
  "description": "OBS browser-source player for Twitch-driven YouTube and SoundCloud song requests.",
  "scripts": {
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "build:bundle-config": "tsx scripts/write-bundled-config.ts",
    "build:server": "tsx scripts/build-runtime.ts",
    "build:electron": "tsx scripts/build-runtime.ts",
    "build:web": "tsx scripts/build-runtime.ts",
    "build:runtime": "tsx scripts/build-runtime.ts",
    "build": "npm run typecheck && npm run build:bundle-config && npm run build:runtime",
    "start": "npm run build:runtime && tsx scripts/run-electron.ts .",
    "start:server": "npm run build:server && node build/server.js",
    "dev": "npm run build:runtime && tsx scripts/run-electron.ts .",
    "dev:server": "tsx watch server.ts",
    "test": "npm run typecheck && npm run build:web && node --import tsx --test src/*.test.ts scripts/*.test.ts",
    "bundle": "npm run build:runtime",
    "build:exe": "npm run build && electron-builder --win portable",
    "build:setup": "npm run build && electron-builder --win nsis",
    "build:release": "npm run build && electron-builder --win",
    "release": "tsx scripts/release.ts",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/tmi.js": "^1.8.6",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.horngaming.twitch-song-request-player",
    "productName": "TwitchSongRequestPlayer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/**/*",
      "playlist.csv",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "TwitchSongRequestPlayer-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "AhornFPS",
      "repo": "twitch-song-request-player"
    },
    "portable": {
      "artifactName": "TwitchSongRequestPlayer-Portable.exe"
    }
  }
}
