{
  "name": "twitch-song-request-player",
  "version": "1.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "description": "OBS browser-source player for Twitch-driven YouTube and SoundCloud song requests.",
  "scripts": {
    "start": "electron .",
    "start:server": "node server.js",
    "dev": "electron .",
    "dev:server": "node --watch server.js",
    "test": "node --test",
    "build:bundle-config": "node scripts/write-bundled-config.js",
    "bundle": "esbuild server.js --bundle --platform=node --format=cjs --outfile=build/server.cjs",
    "build:exe": "npm run build:bundle-config && electron-builder --win portable",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.1"
  },
  "build": {
    "appId": "com.horngaming.twitch-song-request-player",
    "productName": "TwitchSongRequestPlayer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "src/**/*",
      "build/bundled-config.json",
      "server.js",
      "playlist.csv",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "TwitchSongRequestPlayer.exe"
    }
  }
}
