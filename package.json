{
  "name": "twitch-song-request-player",
  "version": "1.0.0",
  "private": true,
  "bin": "build/server.cjs",
  "type": "module",
  "description": "OBS browser-source player for Twitch-driven YouTube and SoundCloud song requests.",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "bundle": "esbuild server.js --bundle --platform=node --format=cjs --outfile=build/server.cjs",
    "build:exe": "npm run bundle && pkg . --targets node20-win-x64 --output dist/TwitchSongRequestPlayer.exe"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.6.0",
    "esbuild": "^0.25.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "playlist.csv"
    ]
  }
}
