PORT=3000
TWITCH_CHANNEL=your_channel_name
# Optional if you use the in-app Twitch login flow:
TWITCH_USERNAME=your_bot_account_name
# Optional if you use the in-app Twitch login flow:
TWITCH_OAUTH_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxx
# Required for the in-app Twitch device login flow. Can be bundled in packaged builds.
TWITCH_CLIENT_ID=your_twitch_app_client_id
# Optional advanced setting. Not needed for the normal in-app login flow.
TWITCH_CLIENT_SECRET=your_twitch_app_client_secret
YOUTUBE_API_KEY=your_youtube_data_api_key
